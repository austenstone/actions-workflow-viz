{
  "name": "actions-workflow-viz-ext",
  "private": true,
  "type": "module",
  "version": "1.0.0",
  "description": "Build tooling for the actions-workflow-viz Copilot canvas extension. Bundles src/*.ts to the committed extension.mjs.",
  "scripts": {
    "build": "node build.mjs",
    "watch": "node build.mjs --watch",
    "dev": "node dev.mjs",
    "typecheck": "tsc -p tsconfig.json && tsc -p tsconfig.web.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@actions/workflow-parser": "^0.3.58",
    "@octokit/plugin-retry": "^8.1.0",
    "@octokit/rest": "^22.0.1",
    "@primer/octicons-react": "^19.28.1",
    "@primer/primitives": "^11.9.0",
    "@primer/react": "^38.28.0",
    "@wterm/dom": "^0.3.0",
    "@wterm/react": "^0.3.0",
    "copilot-canvas-kit": "file:../../../source/copilot-canvas-kit",
    "motion": "^12.40.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "esbuild": "^0.28.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
